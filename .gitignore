#==============================================================================
# .gitignore — Matrix Multiplier Systolic Array
#==============================================================================
# Strategy: ignore everything by default, then explicitly whitelist
# source files. This prevents simulation artifacts and build outputs
# from accidentally being committed.
#==============================================================================

# ---- 1. Ignore everything ----
*

# ---- 2. Un-ignore directories (so git can traverse into them) ----
!*/

# ---- 3. Always track .gitignore itself ----
!.gitignore

# ---- 4. Source directories ----
!/src/
!/src/**
!/tb/
!/tb/**
!/scripts/
!/scripts/**
!/docs/**

# ---- 5. File types to track ----
!*.sv        # SystemVerilog sources
!*.v         # Verilog sources
!*.py        # Python scripts (golden model)
!*.tcl       # Tcl scripts
!*.sh        # Shell scripts
!*.md        # Markdown documentation
!*.json      # JSON config files
!*.xdc       # XDC constraint files

# ---- 6. Explicit ignores (simulation build artifacts) ----
xsim_work/
xsim_manual/
sim_build_pe/
*.wdb
*.vcd
*.log
*.jou
*.pb
*.str
webtalk*.txt
webtalk*.backup
*.backup.jou
*.backup.log
vivado_*
.xsim/
